---
layout: base.njk
title: Notícias
---

<section class="news-header">
  <h1>Notícias</h1>
  <p>As notícias mais importantes do mercado financeiro, economia e negócios</p>
</section>

<section class="category-filter">
  <button class="filter-btn active">Todos</button>
  <button class="filter-btn">Economia</button>
  <button class="filter-btn">Mercados</button>
  <button class="filter-btn">Empresas</button>
  <button class="filter-btn">Tecnologia</button>
  <button class="filter-btn">Finanças Pessoais</button>
  <button class="filter-btn">Política</button>
  <button class="filter-btn">Internacional</button>
</section>

<div class="main-content">
  <div class="content-left">
    <section class="news-grid">
      {%- if collections.post -%} {%- for post in collections.post | reverse -%}
      <article class="news-card">
        <div class="news-card-image">
          <img src="{{ post.data.image }}" alt="{{ post.data.title }}" />
          <span class="tag {{ post.data.category | lower }}">{{
            post.data.category
          }}</span>
        </div>
        <div class="news-card-content">
          <h3>
            <a href="{{ post.url }}">{{ post.data.title }}</a>
          </h3>
          <p>{{ post.data.description }}</p>
          <div class="news-meta">
            <span class="date"
              ><i class="far fa-calendar"></i>
              {{ post.date | formatDate }}</span
            >
            <span class="time"
              ><i class="far fa-clock"></i> {{ post.data.readingTime }}</span
            >
          </div>
        </div>
      </article>
      {%- endfor -%} {%- else -%}
      <p>Nenhuma notícia disponível no momento.</p>
      {%- endif -%}
    </section>

    <div class="pagination">
      <a href="#" class="prev-page"
        ><i class="fas fa-chevron-left"></i> Anterior</a
      >
      <ul class="page-numbers">
        <li><a href="#" class="active">1</a></li>
        <li><a href="#">2</a></li>
        <li><a href="#">3</a></li>
      </ul>
      <a href="#" class="next-page"
        >Próximo <i class="fas fa-chevron-right"></i
      ></a>
    </div>
  </div>

  <div class="sidebar">
    <section class="market-indices">
      <h3>Índices de Mercado atualizados diariamente.</h3>
      <ul class="indices-list">
        <li class="index-item up">
          <span class="index-name">IBOVESPA</span>
          <span class="index-value" id="ibov-value"></span>
          <span class="index-change" id="ibov-change"></span>
        </li>
        <li class="index-item down">
          <span class="index-name">S&P 500</span>
          <span class="index-value" id="sp500-value"></span>
          <span class="index-change" id="sp500-change"></span>
        </li>
        <li class="index-item up">
          <span class="index-name">NASDAQ</span>
          <span class="index-value" id="nasdaq-value"></span>
          <span class="index-change" id="nasdaq-change"></span>
        </li>
      </ul>
    </section>

    <section class="most-read">
      <div class="section-header">
        <h3>Mais Lidas</h3>
        <a href="#" class="view-all"><i class="fas fa-ellipsis-h"></i></a>
      </div>
      <ol class="most-read-list">
        {%- if collections.post -%} {%- for post in collections.post |
        sortByViews | limit(5) -%}
        <li>
          <a href="{{ post.url }}">{{ post.data.title }}</a>
        </li>
        {%- endfor -%} {%- else -%}
        <li>Nenhuma notícia disponível.</li>
        {%- endif -%}
      </ol>
    </section>

    <section class="topics">
      <div class="section-header">
        <h3>Tópicos</h3>
        <a href="#" class="view-all"><i class="fas fa-ellipsis-h"></i></a>
      </div>
      <div class="topics-grid">
        {%- if collections.categories -%} {%- for category in
        collections.categories -%}
        <a href="/categoria/{{ category | lower }}" class="topic-tag">{{
          category
        }}</a>
        {%- endfor -%} {%- else -%}
        <p>Nenhuma categoria disponível.</p>
        {%- endif -%}
      </div>
    </section>
  </div>
</div>
