---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ title }} | InvestSavy</title>
    <link rel="stylesheet" href="/css/style-post.css" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <!-- Header específico para posts -->
    <header class="post-header">
      <div class="container-LOGO">
        <div class="logo">
          <a href="/"
            ><span style="color: #1e40af">Invest</span
            ><span style="color: #10b981">Savy</span></a
          >
        </div>
      </div>

      <nav class="nav-menu">
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/news/">Notícias</a></li>
          <li><a href="/servicos.html">Ferramentas</a></li>
          <li><a href="/educacao.html">Aprender</a></li>
          <li><a href="/sobre.html">Sobre</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <section class="news-header">
        <h1>{{ title }}</h1>
        <div class="news-meta">
          <span class="date"
            ><i class="far fa-calendar"></i> {{ date | formatDate }}</span
          >
          <span class="category"
            ><i class="fas fa-tag"></i> {{ category }}</span
          >
          <span class="reading-time"
            ><i class="far fa-clock"></i> {{ readingTime }} min de leitura</span
          >
        </div>
      </section>

      <article class="news-content">
        {{ content | safe }}
      </article>

      <section class="related-news">
        <h2>Notícias Relacionadas</h2>
        <div class="news-grid">
          {%- for post in collections.post | reverse | limit(3) -%} {%- if
          post.url != page.url -%}
          <article class="news-card">
            <div class="news-card-image">
              <img src="{{ post.data.image }}" alt="{{ post.data.title }}" />
              <span class="tag {{ post.data.category | lower }}">{{
                post.data.category
              }}</span>
            </div>
            <div class="news-card-content">
              <h3>
                <a href="{{ post.url }}">{{ post.data.title }}</a>
              </h3>
              <p>{{ post.data.description }}</p>
              <div class="news-meta">
                <span class="date"
                  ><i class="far fa-calendar"></i>
                  {{ post.date | formatDate }}</span
                >
              </div>
            </div>
          </article>
          {%- endif -%} {%- endfor -%}
        </div>
      </section>
    </main>

    <!-- Footer específico para posts -->
    <footer class="post-footer">
      <div class="container-footer-alt">
        <div class="footer-brand">
          <div class="logo-footer">
            <span style="color: #1e40af">Invest</span
            ><span style="color: #10b981">Savy</span>
          </div>
          <p>Democratizando o acesso à educação<br />financeira para todos.</p>
          <p class="copyright">
            &copy; 2025 InvestSavy. Todos os direitos reservados.
          </p>
        </div>
        <div class="footer-links">
          <h4>NAVEGAÇÃO</h4>
          <ul>
            <li><a href="/">Página Inicial</a></li>
            <li><a href="/news/">Notícias</a></li>
            <li><a href="/servicos.html">Ferramentas</a></li>
            <li><a href="/educacao.html">Educação Financeira</a></li>
            <li><a href="/sobre.html">Sobre Nós</a></li>
          </ul>
        </div>
        <div class="footer-tools">
          <h4>FERRAMENTAS</h4>
          <ul>
            <li>
              <a href="/calculadora-juros">Calculadora de Juros Compostos</a>
            </li>
            <li>
              <a href="/simulador-aposentadoria">Simulador de Aposentadoria</a>
            </li>
            <li>
              <a href="/comparador-investimentos"
                >Comparador de Investimentos</a
              >
            </li>
          </ul>
        </div>
        <div class="footer-contact">
          <h4>CONTATO</h4>
          <p>contato@investsavy.com.br</p>
          <div class="social-icons">
            <a href="#"><i class="fab fa-facebook-f"></i></a>
            <a href="#"><i class="fab fa-instagram"></i></a>
            <a href="#"><i class="fab fa-twitter"></i></a>
            <a href="#"><i class="fab fa-linkedin-in"></i></a>
          </div>
        </div>
      </div>
    </footer>

    <script src="/script/js-universal.js"></script>
    <script
      src="https://kit.fontawesome.com/e1063b7707.js"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
