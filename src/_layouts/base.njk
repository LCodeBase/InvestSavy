<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="InvestSavy - Notícias e análises do mercado financeiro"
    />
    <meta
      name="keywords"
      content="finanças, notícias financeiras, mercado financeiro, investimentos, economia, bolsa de valores"
    />
    <meta name="author" content="InvestSavy" />
    <title>{{ title }} - InvestSavy</title>
    <link rel="stylesheet" href="/css/style-base-noticia.css" />
    <link rel="stylesheet" href="/css/animations.css" />
    <link rel="shortcut icon" href="/images/Camada 1.png" type="image/x-icon" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header>
      <div class="container-LOGO">
        <div class="logo">
          <span style="color: #1e40af">Invest</span
          ><span style="color: #10b981">Savy</span>
        </div>
      </div>

      <div class="menu-toggle" alt="Botão-Menu">
        <i class="fas fa-bars"></i>
      </div>

      <nav class="nav-menu">
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/posts">Notícias</a></li>
          <li><a href="/servicos">Ferramentas</a></li>
          <li><a href="/educacao">Aprender</a></li>
          <li><a href="/sobre">Sobre</a></li>
        </ul>
      </nav>

      <div class="search-icon">
        <i class="fas fa-search"></i>
      </div>
    </header>

    <main>
      <div class="container">
        {{ content | safe }}
      </div>
    </main>

    <footer>
      <div class="container-footer-alt">
        <div class="footer-brand">
          <div class="logo-footer">
            <span style="color: #1e40af">Invest</span
            ><span style="color: #10b981">Savy</span>
          </div>
          <p>Democratizando o acesso à educação<br />financeira para todos.</p>
          <p class="copyright">
            &copy; {{ page.date.getFullYear() }} InvestSavy. Todos os
            direitos<br />reservados.
          </p>
        </div>
        <div class="footer-links">
          <h4>NAVEGAÇÃO</h4>
          <ul>
            <li><a href="/">Página Inicial</a></li>
            <li><a href="/posts">Notícias</a></li>
            <li><a href="/servicos">Ferramentas</a></li>
            <li><a href="/educacao">Educação Financeira</a></li>
            <li><a href="/sobre">Sobre Nós</a></li>
          </ul>
        </div>
        <div class="footer-tools">
          <h4>FERRAMENTAS</h4>
          <ul>
            <li>
              <a href="/calculadora-juros">Calculadora de Juros Compostos</a>
            </li>
            <li>
              <a href="/simulador-aposentadoria">Simulador de Aposentadoria</a>
            </li>
            <li>
              <a href="/comparador-investimentos"
                >Comparador de Investimentos</a
              >
            </li>
          </ul>
        </div>
        <div class="footer-contact">
          <h4>CONTATO</h4>
          <p>contato@investsavy.com.br</p>
          <div class="social-icons">
            <a href="#"><i class="fab fa-facebook-f"></i></a>
            <a href="#"><i class="fab fa-instagram"></i></a>
            <a href="#"><i class="fab fa-twitter"></i></a>
            <a href="#"><i class="fab fa-linkedin-in"></i></a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Scripts -->
    <script src="/script/noticias.js"></script>
    <script src="/script/js-universal.js"></script>
    <script src="/script/market-data.js"></script>
    <script
      src="https://kit.fontawesome.com/e1063b7707.js"
      crossorigin="anonymous"
      async
    ></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.21.1/axios.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.1/moment.min.js"></script>
  </body>
</html>
